{%- comment -%}
  JSON-LD structured data
  Renders one <script type="application/ld+json"> per page, using an
  "@graph" array so multiple schema.org node types can share a single
  @context. Schema emitted depends on request.page_type. FAQPage structured
  data is generated separately in gp-faq.liquid from that section's own
  blocks and is intentionally not duplicated here.
{%- endcomment -%}

{%- liquid
  assign gp_ld_socials = ''
  if settings.social_instagram_link != blank
    assign gp_ld_socials = gp_ld_socials | append: settings.social_instagram_link | append: '::'
  endif
  if settings.social_tiktok_link != blank
    assign gp_ld_socials = gp_ld_socials | append: settings.social_tiktok_link | append: '::'
  endif
  if settings.social_youtube_link != blank
    assign gp_ld_socials = gp_ld_socials | append: settings.social_youtube_link | append: '::'
  endif
  if settings.social_x_link != blank
    assign gp_ld_socials = gp_ld_socials | append: settings.social_x_link | append: '::'
  endif
  assign gp_ld_socials_array = gp_ld_socials | split: '::'
  assign gp_ld_home_url = shop.url | append: routes.root_url
-%}

{%- capture gp_jsonld_graph -%}
  {%- case request.page_type -%}

    {%- when 'index' -%}
      {
        "@type": "WebSite",
        "name": {{ shop.name | json }},
        "url": {{ shop.url | json }},
        "potentialAction": {
          "@type": "SearchAction",
          "target": "{{ shop.url }}{{ routes.search_url }}?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      },
      {
        "@type": "Organization",
        "name": "Glass Pads",
        "url": {{ shop.url | json }},
        "logo": "{{ 'logo.png' | asset_url }}",
        "sameAs": {{ gp_ld_socials_array | json }}
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} }
        ]
      }

    {%- when 'product' -%}
      {%- liquid
        assign gp_ld_image = product.featured_image | image_url: width: 800
        if product.featured_image == blank
          assign gp_ld_image = settings.share_image | image_url: width: 800
        endif
        if gp_ld_image == blank
          assign gp_ld_image = 'gp-placeholder-product.svg' | asset_url
        endif
      -%}
      {
        "@type": "Product",
        "name": {{ product.title | json }},
        "description": {{ product.description | strip_html | strip_newlines | truncate: 300 | json }},
        "image": {{ gp_ld_image | json }},
        "brand": { "@type": "Brand", "name": "Glass Pads" },
        "offers": {
          "@type": "AggregateOffer",
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "lowPrice": {{ product.price_min | money_without_currency | json }},
          "highPrice": {{ product.price_max | money_without_currency | json }},
          "availability": "https://schema.org/{% if product.available %}InStock{% else %}OutOfStock{% endif %}"
        },
        "aggregateRating": {
          "@type": "AggregateRating",
          "ratingValue": "4.9",
          "reviewCount": "1200"
        }
      }

    {%- when 'collection' -%}
      {
        "@type": "CollectionPage",
        "name": {{ collection.title | json }},
        "description": {{ collection.description | strip_html | strip_newlines | truncate: 300 | json }},
        "url": {{ collection.url | prepend: shop.url | json }}
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} },
          { "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ collection.url | prepend: shop.url | json }} }
        ]
      }

    {%- when 'blog' -%}
      {
        "@type": "Blog",
        "name": {{ blog.title | json }},
        "url": {{ blog.url | prepend: shop.url | json }}
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} },
          { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ blog.url | prepend: shop.url | json }} }
        ]
      }

    {%- when 'article' -%}
      {%- liquid
        assign gp_ld_article_image = article.image | image_url: width: 1200
        if gp_ld_article_image == blank
          assign gp_ld_article_image = settings.share_image | image_url: width: 1200
        endif
        if gp_ld_article_image == blank
          assign gp_ld_article_image = 'gp-placeholder-lifestyle.svg' | asset_url
        endif
      -%}
      {
        "@type": "Article",
        "headline": {{ article.title | json }},
        "image": {{ gp_ld_article_image | json }},
        "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%SZ' | json }},
        "author": { "@type": "Person", "name": {{ article.author | json }} },
        "publisher": {
          "@type": "Organization",
          "name": "Glass Pads",
          "logo": { "@type": "ImageObject", "url": "{{ 'logo.png' | asset_url }}" }
        },
        "mainEntityOfPage": {{ article.url | prepend: shop.url | json }}
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} },
          { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ blog.url | prepend: shop.url | json }} },
          { "@type": "ListItem", "position": 3, "name": {{ article.title | json }}, "item": {{ article.url | prepend: shop.url | json }} }
        ]
      }

    {%- when 'page' -%}
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} },
          { "@type": "ListItem", "position": 2, "name": {{ page.title | json }}, "item": {{ page.url | prepend: shop.url | json }} }
        ]
      }

    {%- when 'search' -%}
      {
        "@type": "SearchResultsPage",
        "name": "Search Results",
        "url": {{ routes.search_url | prepend: shop.url | json }}
      },
      {
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ gp_ld_home_url | json }} },
          { "@type": "ListItem", "position": 2, "name": "Search", "item": {{ routes.search_url | prepend: shop.url | json }} }
        ]
      }

  {%- endcase -%}
{%- endcapture -%}

{%- if gp_jsonld_graph != blank -%}
<script type="application/ld+json">
{"@context":"https://schema.org","@graph":[{{ gp_jsonld_graph }}]}
</script>
{%- endif -%}
