{%- comment -%}
  Star rating display in Glass Cyan (brand accent, not generic yellow).
  Params:
    rating - numeric rating out of 5, supports halves/decimals (required)
    label  - optional visually-hidden accessible label override
{%- endcomment -%}

{%- liquid
  assign full_stars = rating | floor
  assign has_half = false
  assign remainder = rating | minus: full_stars
  if remainder >= 0.5
    assign has_half = true
  endif
  assign empty_stars = 5 | minus: full_stars
  if has_half
    assign empty_stars = empty_stars | minus: 1
  endif
-%}

<span class="gp-star-rating" role="img" aria-label="{{ label | default: rating | append: ' out of 5 stars' }}">
  {%- for i in (1..full_stars) -%}
    {% render 'gp-icon', icon: 'star', class: 'gp-star-rating__star gp-star-rating__star--full' %}
  {%- endfor -%}
  {%- if has_half -%}
    {% render 'gp-icon', icon: 'star', class: 'gp-star-rating__star gp-star-rating__star--half' %}
  {%- endif -%}
  {%- for i in (1..empty_stars) -%}
    {% render 'gp-icon', icon: 'star-outline', class: 'gp-star-rating__star gp-star-rating__star--empty' %}
  {%- endfor -%}
</span>
