        "label": "Primary text (Pure White)",
        "default": "#F5F6F7"
      },
      {
        "type": "color",
        "id": "color_text_secondary",
        "label": "Secondary text (Cool Gray)",
        "default": "#9B9DA3"
      },
      {
        "type": "color",
        "id": "color_cyan",
        "label": "Accent — Glass Cyan",
        "default": "#5EE6D9"
      },
      {
        "type": "color",
        "id": "color_violet",
        "label": "Accent — Electric Violet",
        "default": "#8B7CF6"
