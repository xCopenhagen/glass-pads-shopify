{%- comment -%}
  Customer Login Page
  Split layout: sign-in form on the left, brand messaging on the right.
  The "Forgot your password?" link swaps to the native recover-password
  form in place (initAuthFormToggle in gp-theme.js) — no page reload, and
  Shopify still redirects back here with the reset-email confirmation.
{%- endcomment -%}

{%- capture recover_form_markup -%}
  {%- form 'recover_customer_password', id: 'GpRecoverForm' -%}
    {%- if form.posted_successfully? -%}
      <div class="gp-contact-success">
        {% render 'gp-icon', icon: 'tick' %}
        <p>If that email has an account, we've sent password reset instructions.</p>
      </div>
    {%- else -%}
      {%- if form.errors -%}
        <div class="gp-contact-form__errors">
          <p>{{ form.errors | default_errors }}</p>
        </div>
      {%- endif -%}

      <div class="gp-contact-form__field">
        <label for="RecoverEmail">Email</label>
        <input type="email" id="RecoverEmail" name="email" autocomplete="email" required>
      </div>

      <button type="submit" class="gp-btn gp-btn--primary gp-contact-form__submit">Send Reset Link</button>
    {%- endif -%}

    <a href="#" class="gp-auth-form__link" data-gp-auth-switch="login">Back to login</a>
  {%- endform -%}
{%- endcapture -%}

{%- assign show_recover_by_default = form.posted_successfully? -%}

<div class="gp-auth-page">
  <div class="gp-auth-page__form-col">
    <div class="gp-container gp-auth-page__form-wrap">
      <div data-gp-auth-toggle>

        <div class="gp-auth-form{% unless show_recover_by_default %} is-active{% endunless %}" data-gp-auth-panel="login" {% if show_recover_by_default %}hidden{% endif %}>
          <h1 class="gp-h2">{{ section.settings.heading }}</h1>
          {%- if section.settings.body != blank -%}
            <p class="gp-body gp-auth-form__intro">{{ section.settings.body }}</p>
          {%- endif -%}

          {%- form 'customer_login', id: 'GpLoginForm' -%}
            {%- if form.errors -%}
              <div class="gp-contact-form__errors">
                <p>{{ form.errors | default_errors }}</p>
              </div>
            {%- endif -%}

            <div class="gp-contact-form__field">
              <label for="LoginEmail">Email</label>
              <input type="email" id="LoginEmail" name="customer[email]" autocomplete="email" required>
            </div>

            <div class="gp-contact-form__field">
              <label for="LoginPassword">Password</label>
              <input type="password" id="LoginPassword" name="customer[password]" autocomplete="current-password" required>
            </div>

            <button type="submit" class="gp-btn gp-btn--primary gp-contact-form__submit">Sign In</button>

            <a href="#" class="gp-auth-form__link" data-gp-auth-switch="recover">Forgot your password?</a>
          {%- endform -%}

          <p class="gp-auth-form__footer">
            New here? <a href="{{ routes.account_register_url }}">Create account</a>
          </p>

          {%- if section.settings.show_guest_checkout -%}
            <p class="gp-auth-form__footer">
              <a href="{{ routes.root_url }}">Continue shopping as guest</a>
            </p>
          {%- endif -%}
        </div>

        <div class="gp-auth-form{% if show_recover_by_default %} is-active{% endif %}" data-gp-auth-panel="recover" {% unless show_recover_by_default %}hidden{% endunless %}>
          <h1 class="gp-h2">{{ section.settings.recover_heading }}</h1>
          {%- if section.settings.recover_body != blank -%}
            <p class="gp-body gp-auth-form__intro">{{ section.settings.recover_body }}</p>
          {%- endif -%}

          {{ recover_form_markup }}
        </div>

      </div>
    </div>
  </div>

  <div class="gp-auth-page__brand-col">
    <div class="gp-auth-page__brand-glow" aria-hidden="true"></div>
    <div class="gp-auth-page__brand-content">
      <h2 class="gp-h2">Welcome Back</h2>
      <p class="gp-body">Your premium desk setup awaits.</p>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Customer Login",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sign In"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Welcome back — sign in to view your orders and manage your account."
    },
    {
      "type": "text",
      "id": "recover_heading",
      "label": "Recover password heading",
      "default": "Reset Your Password"
    },
    {
      "type": "textarea",
      "id": "recover_body",
      "label": "Recover password body",
      "default": "Enter your email and we'll send you a link to reset your password."
    },
    {
      "type": "checkbox",
      "id": "show_guest_checkout",
      "label": "Show \"continue as guest\" link",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Customer Login"
    }
  ]
}
{% endschema %}
