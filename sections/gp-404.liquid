{%- comment -%}
  404 Error Page
  Branded "lost your way" page — a large low-opacity "404" watermark sits
  behind the copy for texture without competing with the headline.
{%- endcomment -%}

<section class="gp-404">
  <div class="gp-404__glow" aria-hidden="true"></div>
  <span class="gp-404__watermark" aria-hidden="true">404</span>

  <div class="gp-container gp-404__content">
    <h1 class="gp-h1">{{ section.settings.heading }}</h1>
    {%- if section.settings.body != blank -%}
      <p class="gp-404__body">{{ section.settings.body }}</p>
    {%- endif -%}

    <div class="gp-404__actions">
      {%- if section.settings.button_text != blank -%}
        {% render 'gp-button', text: section.settings.button_text, url: section.settings.button_link, style: 'primary' %}
      {%- endif -%}
      {%- if section.settings.secondary_text != blank -%}
        {% render 'gp-button', text: section.settings.secondary_text, url: section.settings.secondary_link, style: 'secondary' %}
      {%- endif -%}
    </div>

    <ul class="gp-404__quick-links">
      <li><a href="/collections/all">Browse all products</a></li>
      <li><a href="/pages/custom-artwork">Custom Artwork</a></li>
      <li><a href="/pages/gallery">Gallery</a></li>
    </ul>
  </div>
</section>

{% schema %}
{
  "name": "404 Error Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Lost Your Way?"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This page doesn't exist. But the perfect glass pad for your desk does."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Primary button text",
      "default": "Shop Glass Pads"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary button link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary button text",
      "default": "Go Home"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link",
      "default": "/"
    }
  ],
  "presets": [
    {
      "name": "404 Error Page"
    }
  ]
}
{% endschema %}
