{%- comment -%}
  Cart Drawer
  Slides in from the right on add-to-cart or cart icon click. Uses the
  native {% form 'cart' %} tag with bulk "updates[]" quantity inputs, so
  Checkout/quantity still work with JS disabled. With JS, initCartDrawer
  in gp-theme.js intercepts quantity/remove actions and re-fetches this
  section's markup via the Section Rendering API (?sections=) to stay in
  sync without a full page reload.
{%- endcomment -%}

<div class="gp-cart-overlay" data-gp-cart-overlay hidden></div>

<aside class="gp-cart-drawer is-closed" id="GpCartDrawer" data-gp-cart-drawer data-section-id="{{ section.id }}" inert>
  <div class="gp-cart-drawer__header">
    <h2 class="gp-h3">{{ section.settings.heading }} <span class="gp-cart-drawer__count" data-gp-cart-drawer-count>({{ cart.item_count }})</span></h2>
    <button type="button" class="gp-cart-drawer__close" data-gp-cart-close aria-label="Close cart">
      {% render 'gp-icon', icon: 'cross' %}
    </button>
  </div>

  {%- if cart.item_count == 0 -%}
    <div class="gp-cart-empty">
      <p class="gp-h3">{{ section.settings.empty_text }}</p>
      {% render 'gp-button', text: section.settings.empty_link_text, url: section.settings.empty_link_url, style: 'primary' %}
    </div>
  {%- else -%}
    {%- liquid
      assign threshold_cents = section.settings.shipping_threshold | times: 100
      assign remaining_cents = threshold_cents | minus: cart.total_price
      assign progress_pct = 100
      if threshold_cents > 0
        assign progress_pct = cart.total_price | times: 100.0 | divided_by: threshold_cents
        if progress_pct > 100
          assign progress_pct = 100
        endif
      endif
    -%}

    {%- if section.settings.shipping_threshold > 0 -%}
      <div class="gp-cart-shipping-bar">
        <p class="gp-cart-shipping-bar__text">
          {%- if remaining_cents <= 0 -%}
            You've unlocked free shipping!
          {%- else -%}
            Add {{ remaining_cents | money }} more for free shipping
          {%- endif -%}
        </p>
        <div class="gp-cart-shipping-bar__track">
          <div class="gp-cart-shipping-bar__fill" style="width: {{ progress_pct }}%;"></div>
        </div>
      </div>
    {%- endif -%}

    {%- form 'cart', cart, data-gp-cart-form: '' -%}
      <div class="gp-cart-drawer__items">
        {%- for item in cart.items -%}
          <div class="gp-cart-item" data-gp-cart-line="{{ forloop.index }}">
            <a href="{{ item.url }}" class="gp-cart-item__image">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="100" loading="lazy">
              {%- endif -%}
            </a>
            <div class="gp-cart-item__details">
              <a href="{{ item.url }}" class="gp-cart-item__title">{{ item.product.title }}</a>
              {%- unless item.variant.title == 'Default Title' -%}
                <p class="gp-cart-item__variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              <p class="gp-cart-item__price">{{ item.final_price | money }}</p>

              <div class="gp-cart-quantity" data-gp-cart-qty-stepper data-line="{{ forloop.index }}">
                <button type="button" class="gp-cart-quantity__btn" data-gp-cart-qty-decrease aria-label="Decrease quantity">{% render 'gp-icon', icon: 'minus' %}</button>
                <input type="number" class="gp-cart-quantity__input" name="updates[]" value="{{ item.quantity }}" min="0" data-gp-cart-qty-input aria-label="Quantity">
                <button type="button" class="gp-cart-quantity__btn" data-gp-cart-qty-increase aria-label="Increase quantity">{% render 'gp-icon', icon: 'plus' %}</button>
              </div>
            </div>
            <button type="button" class="gp-cart-remove" data-gp-cart-remove data-line="{{ forloop.index }}" aria-label="Remove {{ item.product.title | escape }}">
              {% render 'gp-icon', icon: 'cross' %}
            </button>
          </div>
        {%- endfor -%}
      </div>

      <div class="gp-cart-footer">
        <div class="gp-cart-footer__subtotal">
          <span>Subtotal</span>
          <span data-gp-cart-subtotal>{{ cart.total_price | money }}</span>
        </div>
        <p class="gp-cart-footer__note">{{ section.settings.shipping_note_text }}</p>
        <button type="submit" name="checkout" class="gp-btn gp-btn--primary gp-btn--full">Checkout</button>
        <button type="button" class="gp-cart-footer__continue" data-gp-cart-close>Continue Shopping</button>
      </div>
    {%- endform -%}
  {%- endif -%}
</aside>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Cart"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty cart message",
      "default": "Your cart is empty"
    },
    {
      "type": "text",
      "id": "empty_link_text",
      "label": "Empty cart button text",
      "default": "Shop Glass Pads"
    },
    {
      "type": "url",
      "id": "empty_link_url",
      "label": "Empty cart button link",
      "default": "/collections/all"
    },
    {
      "type": "number",
      "id": "shipping_threshold",
      "label": "Free shipping threshold ($)",
      "info": "Set to 0 to hide the free shipping progress bar.",
      "default": 30
    },
    {
      "type": "text",
      "id": "shipping_note_text",
      "label": "Shipping note",
      "default": "Shipping and taxes calculated at checkout."
    }
  ],
  "presets": [
    {
      "name": "Cart Drawer"
    }
  ]
}
{% endschema %}
