{%- comment -%}
  Artist Program Page
  One modular section with block types (hero, benefits, cta, gallery, faq)
  that together build the /pages/artist-program recruitment page.
  "benefit", "past_drop", and "faq_item" are repeatable child blocks — add as
  many as needed under their parent block type; they render nested inside
  the matching benefits/gallery/faq block wherever it sits in the block order.
{%- endcomment -%}

{%- liquid
  assign benefits = section.blocks | where: "type", "benefit"
  assign past_drops = section.blocks | where: "type", "past_drop"
  assign faq_items = section.blocks | where: "type", "faq_item"
-%}

<div class="gp-artist-program">
  {%- for block in section.blocks -%}
    {%- case block.type -%}

      {%- when 'hero' -%}
        <div class="gp-artist-program-hero" {{ block.shopify_attributes }}>
          <div class="gp-artist-program-hero__glow" aria-hidden="true"></div>
          <div class="gp-container gp-artist-program-hero__content">
            <p class="gp-eyebrow">Artist Program</p>
            <h1 class="gp-h1">{{ block.settings.heading }}</h1>
            {%- if block.settings.body != blank -%}
              <p class="gp-artist-program-hero__body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <div class="gp-artist-program-hero__actions">
                {% render 'gp-button', text: block.settings.button_text, url: block.settings.button_link, style: 'primary' %}
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'benefits' -%}
        <div class="gp-artist-benefits gp-section gp-bg-secondary" {{ block.shopify_attributes }}>
          <div class="gp-container">
            {% render 'gp-section-header', heading: block.settings.heading %}
            <div class="gp-artist-benefits__grid">
              {%- for benefit in benefits -%}
                <div class="gp-artist-benefit-card gp-fade-in" {{ benefit.shopify_attributes }}>
                  {% render 'gp-icon', icon: benefit.settings.icon, class: 'gp-artist-benefit-card__icon' %}
                  <h3 class="gp-h3">{{ benefit.settings.title }}</h3>
                  <p class="gp-body">{{ benefit.settings.description }}</p>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>

      {%- when 'cta' -%}
        <div class="gp-artist-cta gp-section" {{ block.shopify_attributes }}>
          <div class="gp-artist-cta__glow" aria-hidden="true"></div>
          <div class="gp-container gp-artist-cta__content">
            <h2 class="gp-h2">{{ block.settings.heading }}</h2>
            {%- if block.settings.body != blank -%}
              <p class="gp-artist-cta__body">{{ block.settings.body }}</p>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <div class="gp-artist-cta__actions">
                {% render 'gp-button', text: block.settings.button_text, url: block.settings.button_link, style: 'primary' %}
              </div>
            {%- endif -%}
          </div>
        </div>

      {%- when 'gallery' -%}
        <div class="gp-artist-drops gp-section gp-bg-primary" {{ block.shopify_attributes }}>
          <div class="gp-container">
            {% render 'gp-section-header', heading: block.settings.heading %}
            <div class="gp-artist-drops__grid">
              {%- for drop in past_drops -%}
                <div class="gp-artist-drop-card gp-fade-in" {{ drop.shopify_attributes }}>
                  {%- if drop.settings.image != blank -%}
                    <img
                      src="{{ drop.settings.image | image_url: width: 700 }}"
                      alt="{{ drop.settings.artist_name | default: 'Past artist collaboration' | escape }}"
                      loading="lazy"
                      width="{{ drop.settings.image.width }}"
                      height="{{ drop.settings.image.height }}"
                    >
                  {%- else -%}
                    <img src="{{ 'gp-placeholder-artwork.svg' | asset_url }}" alt="{{ drop.settings.artist_name | escape }}" loading="lazy">
                  {%- endif -%}
                  <div class="gp-artist-drop-card__info">
                    <p class="gp-artist-drop-card__name">{{ drop.settings.artist_name }}</p>
                    {%- if drop.settings.drop_title != blank -%}
                      <p class="gp-artist-drop-card__title">{{ drop.settings.drop_title }}</p>
                    {%- endif -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </div>

      {%- when 'faq' -%}
        <div class="gp-artist-faq gp-section gp-bg-secondary" {{ block.shopify_attributes }}>
          <div class="gp-container gp-faq__container">
            {% render 'gp-section-header', heading: block.settings.heading, align: 'left' %}
            <div class="gp-faq__list">
              {%- for item in faq_items -%}
                <details class="gp-faq-item" {{ item.shopify_attributes }}>
                  <summary class="gp-faq-item__question">
                    <span>{{ item.settings.question }}</span>
                    <span class="gp-faq-item__toggle">
                      {% render 'gp-icon', icon: 'plus', class: 'gp-faq-item__icon-plus' %}
                      {% render 'gp-icon', icon: 'minus', class: 'gp-faq-item__icon-minus' %}
                    </span>
                  </summary>
                  <div class="gp-faq-item__answer gp-body">{{ item.settings.answer }}</div>
                </details>
              {%- endfor -%}
            </div>
          </div>
        </div>

      {%- else -%}
        {%- comment -%} benefit, past_drop, and faq_item blocks render inside their parent block above. {%- endcomment -%}

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Artist Program Page",
  "settings": [],
  "blocks": [
    {
      "type": "hero",
      "name": "Hero",
      "settings": [
        { "type": "text", "id": "heading", "label": "Headline", "default": "Your Art. Our Glass. A Global Canvas." },
        { "type": "textarea", "id": "body", "label": "Body copy", "default": "Your work printed, sealed under glass, and shipped to premium desk setups worldwide." },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Apply as an Artist" },
        { "type": "url", "id": "button_link", "label": "Button link", "info": "Link to your contact form." }
      ]
    },
    {
      "type": "benefits",
      "name": "Benefits",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Why Artists Partner With Us" }
      ]
    },
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "award", "label": "Award" },
            { "value": "globe", "label": "Globe" },
            { "value": "palette", "label": "Palette" }
          ],
          "default": "award"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Royalties on Every Sale" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Earn a percentage of every pad featuring your artwork." }
      ]
    },
    {
      "type": "gallery",
      "name": "Past Collaborations",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Past Collaborations" }
      ]
    },
    {
      "type": "past_drop",
      "name": "Past Drop",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "artist_name", "label": "Artist name", "default": "Artist Name" },
        { "type": "text", "id": "drop_title", "label": "Drop title", "default": "Drop 001 — Origins" }
      ]
    },
    {
      "type": "cta",
      "name": "Closing CTA",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to See Your Art in Glass?" },
        { "type": "textarea", "id": "body", "label": "Body copy", "default": "Apply today and hear back within 5 business days." },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Apply as an Artist" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Artist Program — FAQ" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How does the program work?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>Submit your portfolio through our application form. If selected, we'll work with you to prepare your artwork for print and launch it as a limited drop.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Artist Program Page",
      "blocks": [
        { "type": "hero", "settings": {} },
        { "type": "benefits", "settings": {} },
        { "type": "benefit", "settings": { "icon": "award", "title": "Royalties on Every Sale", "description": "Earn a percentage of every pad featuring your artwork." } },
        { "type": "benefit", "settings": { "icon": "globe", "title": "Global Exposure", "description": "Your work featured on premium desks in 20+ countries." } },
        { "type": "benefit", "settings": { "icon": "palette", "title": "Creative Freedom", "description": "Full-size canvases at 2:1 and 1:1 ratios. No brand restrictions." } },
        { "type": "gallery", "settings": {} },
        { "type": "past_drop", "settings": { "artist_name": "Artist Name", "drop_title": "Drop 003 — Nebula" } },
        { "type": "past_drop", "settings": { "artist_name": "Artist Name", "drop_title": "Drop 002 — Circuit" } },
        { "type": "past_drop", "settings": { "artist_name": "Artist Name", "drop_title": "Drop 001 — Origins" } },
        { "type": "cta", "settings": {} },
        { "type": "faq", "settings": {} },
        { "type": "faq_item", "settings": { "question": "How does the program work?", "answer": "<p>Submit your portfolio through our application form. If selected, we'll work with you to prepare your artwork for print and launch it as a limited drop.</p>" } },
        { "type": "faq_item", "settings": { "question": "Who owns the rights to my artwork?", "answer": "<p>You retain full ownership of your original artwork. We license it exclusively for use on Glass Pads products for the duration of the drop.</p>" } },
        { "type": "faq_item", "settings": { "question": "What's the timeline from application to launch?", "answer": "<p>Most drops go from approved application to live product in 4-6 weeks, depending on production scheduling.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is my design exclusive to Glass Pads?", "answer": "<p>During an active drop, yes. After the drop concludes, exclusivity terms are outlined in your artist agreement.</p>" } }
      ]
    }
  ]
}
{% endschema %}
