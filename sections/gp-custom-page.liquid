      "name": "Example",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "label", "label": "Label", "default": "Custom Photo Print" },
        { "type": "textarea", "id": "description", "label": "Description (optional)" }
      ]
    },
    {
      "type": "cta",
      "name": "Closing CTA",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Ready to Create?" },
        { "type": "textarea", "id": "body", "label": "Body copy", "default": "Upload your artwork and we'll take care of the rest. Free shipping on every custom order." },
        { "type": "text", "id": "button_text", "label": "Button text", "default": "Start Your Custom Design" },
        { "type": "url", "id": "button_link", "label": "Button link" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Custom Orders — FAQ" }
      ]
    },
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "What file formats do you accept?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>JPEG, PNG, and TIFF. For vector artwork, we prefer high-res PNG exports.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Artwork Page",
      "blocks": [
        { "type": "hero", "settings": {} },
        { "type": "specs", "settings": {} },
        { "type": "spec_card", "settings": { "icon": "ruler", "title": "Desk Pad (2:1 Ratio)", "description": "Width × Height = 2:1 aspect ratio. Perfect for full desk coverage. Recommended: 3600 × 1800px at 300 DPI." } },
        { "type": "spec_card", "settings": { "icon": "ruler", "title": "Standard Pad (Square — 9×9\")", "description": "A perfect square. Ideal for standalone mouse use. Recommended: 2700 × 2700px at 300 DPI." } },
        { "type": "spec_card", "settings": { "icon": "image", "title": "Maximum Resolution", "description": "The higher the better. We recommend 300 DPI minimum. JPEG, PNG, or TIFF accepted." } },
        { "type": "spec_card", "settings": { "icon": "shield", "title": "Safe Zones", "description": "Keep critical artwork away from edges. We provide a downloadable template with marked safe zones." } },
        { "type": "how-it-works", "settings": {} },
        { "type": "gallery", "settings": {} },
        { "type": "gallery_example", "settings": { "label": "Custom Photo Print" } },
        { "type": "gallery_example", "settings": { "label": "Custom Pattern" } },
        { "type": "gallery_example", "settings": { "label": "Brand Logo" } },
        { "type": "gallery_example", "settings": { "label": "Original Artwork" } },
        { "type": "cta", "settings": {} },
        { "type": "faq", "settings": {} },
        { "type": "faq_item", "settings": { "question": "What file formats do you accept?", "answer": "<p>JPEG, PNG, and TIFF. For vector artwork, we prefer high-res PNG exports.</p>" } },
        { "type": "faq_item", "settings": { "question": "What's the turnaround time?", "answer": "<p>Custom orders ship within 5-7 business days from approval. Each pad is made to order.</p>" } },
        { "type": "faq_item", "settings": { "question": "Can I request color matching?", "answer": "<p>We print with high-fidelity UV printing. Colors appear vibrant and accurate, though some variation may occur between screen and print.</p>" } },
        { "type": "faq_item", "settings": { "question": "What if my artwork doesn't fit?", "answer": "<p>We'll review every submission and contact you if resizing or adjustments are needed.</p>" } },
        { "type": "faq_item", "settings": { "question": "Can I order a custom pad for my business or brand?", "answer": "<p>Absolutely. Custom branding orders are welcome — contact us for bulk pricing.</p>" } },
        { "type": "faq_item", "settings": { "question": "Is the custom artwork covered by the glass the same way?", "answer": "<p>Yes. Custom artwork is sealed under glass with the same process as our standard designs — it will never fade, peel, or rub off.</p>" } }
      ]
    }
  ]
}
{% endschema %}
