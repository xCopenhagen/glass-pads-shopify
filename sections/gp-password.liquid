{%- comment -%}
  Password / Coming Soon Page
  Rendered by layout/password.liquid (no nav/footer chrome). Email capture
  uses the native customer form tag (same "newsletter" tag as the footer
  signup); store-access uses Shopify's native storefront_password form.
{%- endcomment -%}

<section class="gp-password-page">
  <div class="gp-password-page__gradient" aria-hidden="true"></div>

  <div class="gp-container gp-password-page__content">
    <p class="gp-password-page__logo">{{ shop.name | default: 'Glass Pads' }}</p>

    <h1 class="gp-h1 gp-password-page__heading">{{ section.settings.heading }}</h1>

    {%- if section.settings.body != blank -%}
      <p class="gp-password-page__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.settings.show_email_form -%}
      {%- form 'customer', class: 'gp-password-page__email-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="gp-password-page__email-row">
          <label for="GpPasswordEmail" class="gp-visually-hidden">Email address</label>
          <input type="email" name="contact[email]" id="GpPasswordEmail" placeholder="Enter your email" required class="gp-password-page__input">
          <button type="submit" class="gp-btn gp-btn--primary">
            <span>Notify Me</span>
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="gp-password-page__success">Thanks — we'll let you know when we launch.</p>
        {%- endif -%}
      {%- endform -%}
    {%- endif -%}

    {%- if section.settings.show_password -%}
      <details class="gp-password-page__access">
        <summary class="gp-password-page__access-toggle">
          {% render 'gp-icon', icon: 'eye' %}
          <span>Have store access?</span>
        </summary>
        {%- form 'storefront_password', class: 'gp-password-page__password-form' -%}
          <label for="GpStorePassword" class="gp-visually-hidden">Password</label>
          <div class="gp-password-page__password-row">
            <input type="password" name="password" id="GpStorePassword" placeholder="Enter password" class="gp-password-page__input">
            <button type="submit" class="gp-btn gp-btn--secondary">
              <span>Enter</span>
            </button>
          </div>
          {%- if form.errors -%}
            <p class="gp-password-page__error">Incorrect password. Please try again.</p>
          {%- endif -%}
        {%- endform -%}
      </details>
    {%- endif -%}
  </div>

  <footer class="gp-password-page__footer">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name | default: 'Glass Pads' }}.</p>
  </footer>
</section>

{% schema %}
{
  "name": "Password Page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coming Soon"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Something exceptional is being crafted. Enter your email to be the first to know when we launch."
    },
    {
      "type": "checkbox",
      "id": "show_email_form",
      "label": "Show email signup form",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_password",
      "label": "Show store password entry",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Password Page"
    }
  ]
}
{% endschema %}
