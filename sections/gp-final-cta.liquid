{%- comment -%}
  Closing Offer Banner
  Toggle "email signup mode" for pre-launch/waitlist positioning, or leave
  in "shop now" mode once the store is live. Email mode posts to Shopify's
  native customer/newsletter form — no third-party app required for MVP.
{%- endcomment -%}

<section class="gp-final-cta gp-section">
  <div class="gp-final-cta__glow" aria-hidden="true"></div>

  <div class="gp-container gp-final-cta__content">
    <h2 class="gp-h2">{{ section.settings.heading }}</h2>
    <p class="gp-final-cta__body">{{ section.settings.body }}</p>

    {%- if section.settings.mode == 'email' -%}
      {%- form 'customer' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="gp-final-cta__email-form">
          <label for="GpFinalCtaEmail-{{ section.id }}" class="gp-visually-hidden">Email address</label>
          <input
            type="email"
            name="contact[email]"
            id="GpFinalCtaEmail-{{ section.id }}"
            class="gp-final-cta__email-input"
            placeholder="Enter your email"
            required
          >
          <button type="submit" class="gp-btn gp-btn--primary">
            <span>{{ section.settings.secondary_btn_text }}</span>
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p class="gp-final-cta__success">You're on the list — we'll be in touch.</p>
        {%- endif -%}
      {%- endform -%}
    {%- else -%}
      <div class="gp-final-cta__actions">
        {% render 'gp-button', text: section.settings.primary_btn_text, url: section.settings.primary_btn_link, style: 'primary' %}
      </div>
    {%- endif -%}

    {%- if section.settings.trust_text != blank -%}
      <div class="gp-final-cta__trust">
        {% render 'gp-icon', icon: 'shipping-truck' %}
        {% render 'gp-icon', icon: 'shield' %}
        {% render 'gp-icon', icon: 'lock' %}
        <span>{{ section.settings.trust_text }}</span>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Closing Offer Banner",
  "settings": [
    {
      "type": "select",
      "id": "mode",
      "label": "Mode",
      "options": [
        { "value": "shop", "label": "Shop now" },
        { "value": "email", "label": "Email signup (pre-launch)" }
      ],
      "default": "shop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade Your Desk. For Good."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body copy",
      "default": "Join thousands who've made the switch to glass. Free shipping on every order, and a 30-day glide guarantee."
    },
    {
      "type": "text",
      "id": "primary_btn_text",
      "label": "Shop mode button text",
      "default": "Shop Glass Pads Now"
    },
    {
      "type": "url",
      "id": "primary_btn_link",
      "label": "Shop mode button link"
    },
    {
      "type": "text",
      "id": "secondary_btn_text",
      "label": "Email mode button text",
      "default": "Join the Launch List"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image (optional)"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust micro-copy",
      "default": "Free Shipping • 30-Day Guarantee • Secure Checkout"
    }
  ],
  "presets": [
    {
      "name": "Closing Offer Banner"
    }
  ]
}
{% endschema %}
