{%- comment -%}
  Collection Hero
  Banner for collection pages — falls back to collection.title/description
  when the editable heading/description are left blank, so it works
  automatically on any collection without setup. Falls back to a Void Black
  background with no image if no banner is set.
{%- endcomment -%}

{%- liquid
  assign hero_heading = section.settings.heading | default: collection.title
  assign hero_description = section.settings.description | default: collection.description
-%}

<section class="gp-collection-hero{% if section.settings.banner_image != blank %} gp-collection-hero--image{% endif %}" style="--gp-collection-hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">
  {%- if section.settings.banner_image != blank -%}
    <img
      class="gp-collection-hero__image"
      src="{{ section.settings.banner_image | image_url: width: 1920 }}"
      srcset="{{ section.settings.banner_image | image_url: width: 960 }} 960w, {{ section.settings.banner_image | image_url: width: 1920 }} 1920w"
      sizes="100vw"
      alt="{{ section.settings.banner_image.alt | default: hero_heading | escape }}"
      loading="eager"
      fetchpriority="high"
      width="{{ section.settings.banner_image.width }}"
      height="{{ section.settings.banner_image.height }}"
    >
    <div class="gp-collection-hero__overlay"></div>
  {%- endif -%}

  <div class="gp-container gp-collection-hero__content">
    <p class="gp-eyebrow">Browse{% if collection.title != blank %} — {{ collection.title }}{% endif %}</p>
    <h1 class="gp-h1 gp-collection-hero__heading">{{ hero_heading }}</h1>
    {%- if hero_description != blank -%}
      <div class="gp-collection-hero__description gp-body">{{ hero_description }}</div>
    {%- endif -%}
    <p class="gp-collection-hero__count gp-mono-spec">{{ collection.products_count }} product{% if collection.products_count != 1 %}s{% endif %}</p>
  </div>
</section>

{% schema %}
{
  "name": "Collection Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use the collection's own title."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "info": "Leave blank to use the collection's own description."
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image",
      "info": "Leave blank for a Void Black background with just text."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55
    }
  ],
  "presets": [
    {
      "name": "Collection Hero"
    }
  ]
}
{% endschema %}
