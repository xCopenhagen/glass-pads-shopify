{%- comment -%}
  Newsletter Signup Popup
  Rendered globally from layout/theme.liquid so it can appear on any page.
  The popup element itself is the full-screen dim backdrop (clicking it
  outside the modal closes the popup — see initNewsletterPopup in
  gp-theme.js). Trigger timing (exit intent / timed / scroll / manual) and
  the "don't show again" localStorage flag are handled entirely in JS;
  this section only renders markup + settings as data attributes.
{%- endcomment -%}

{%- if section.settings.enable_popup -%}
  <div
    class="gp-popup-overlay"
    data-gp-newsletter-popup
    data-gp-enabled="{{ section.settings.enable_popup }}"
    data-gp-show-on-mobile="{{ section.settings.show_on_mobile }}"
    data-gp-trigger="{{ section.settings.trigger_type }}"
    data-gp-delay="{{ section.settings.trigger_delay }}"
    data-gp-scroll-percentage="{{ section.settings.scroll_percentage }}"
    role="dialog"
    aria-modal="true"
    aria-label="{{ section.settings.heading | escape }}"
    inert
  >
    <div class="gp-popup-modal">
      <button type="button" class="gp-popup-close" data-gp-popup-close aria-label="Close">
        {% render 'gp-icon', icon: 'cross' %}
      </button>

      <div class="gp-popup-content">
        {%- if section.settings.discount_text != blank -%}
          <span class="gp-popup-badge">
            {% render 'gp-icon', icon: 'gift' %}
            {{ section.settings.discount_text }}
          </span>
        {%- endif -%}

        <h2 class="gp-h2">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <p class="gp-popup-body">{{ section.settings.body }}</p>
        {%- endif -%}

        {%- form 'customer', class: 'gp-popup-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          {%- if form.posted_successfully? -%}
            <div class="gp-popup-success">
              {% render 'gp-icon', icon: 'tick' %}
              <p>{{ section.settings.success_message }}</p>
            </div>
          {%- else -%}
            <div class="gp-popup-form__row">
              <label for="GpPopupEmail-{{ section.id }}" class="gp-visually-hidden">Email address</label>
              <input type="email" name="contact[email]" id="GpPopupEmail-{{ section.id }}" placeholder="Enter your email" required class="gp-popup-input">
              <button type="submit" class="gp-btn gp-btn--primary">
                <span>{{ section.settings.button_text }}</span>
              </button>
            </div>
          {%- endif -%}
        {%- endform -%}

        <label class="gp-popup-checkbox">
          <input type="checkbox" data-gp-popup-dont-show>
          <span>Don't show again</span>
        </label>

        <a href="#" class="gp-popup-dismiss" data-gp-popup-dismiss>{{ section.settings.dismiss_text }}</a>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_popup",
      "label": "Enable popup",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get 10% Off Your First Order."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Be the first to know about new drops, artist collaborations, and exclusive designs."
    },
    {
      "type": "text",
      "id": "discount_text",
      "label": "Discount badge text",
      "default": "Get 10% off your first order"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You're in — check your inbox for your 10% off code."
    },
    {
      "type": "text",
      "id": "dismiss_text",
      "label": "Dismiss link text",
      "default": "No thanks, I'll pay full price"
    },
    {
      "type": "select",
      "id": "trigger_type",
      "label": "Trigger",
      "options": [
        { "value": "exit_intent", "label": "Exit intent" },
        { "value": "timed", "label": "Timed delay" },
        { "value": "scroll", "label": "Scroll percentage" },
        { "value": "manual", "label": "Manual only" }
      ],
      "default": "timed"
    },
    {
      "type": "range",
      "id": "trigger_delay",
      "label": "Timed delay (seconds)",
      "min": 5,
      "max": 60,
      "step": 5,
      "default": 15
    },
    {
      "type": "range",
      "id": "scroll_percentage",
      "label": "Scroll trigger percentage",
      "min": 25,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Newsletter Popup"
    }
  ]
}
{% endschema %}
