<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="#0A0A0C">

  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
    {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {%- liquid
    assign gp_meta_description = page_description | default: settings.og_default_description | default: shop.description
    assign gp_meta_type = 'website'
    assign gp_meta_image = settings.share_image | image_url: width: 1200

    case request.page_type
      when 'product'
        assign gp_meta_type = 'product'
        if product.featured_image != blank
          assign gp_meta_image = product.featured_image | image_url: width: 1200
        endif
        if gp_meta_description == blank
          assign gp_meta_description = product.description | strip_html | strip_newlines | truncate: 200
        endif
      when 'article'
        assign gp_meta_type = 'article'
        if article.image != blank
          assign gp_meta_image = article.image | image_url: width: 1200
        endif
        if gp_meta_description == blank
          assign gp_meta_description = article.excerpt | strip_html | strip_newlines | truncate: 200
          if gp_meta_description == blank
            assign gp_meta_description = article.content | strip_html | strip_newlines | truncate: 200
          endif
        endif
      when 'collection'
        if collection.image != blank
          assign gp_meta_image = collection.image | image_url: width: 1200
        endif
        if gp_meta_description == blank
          assign gp_meta_description = collection.description | strip_html | strip_newlines | truncate: 200
        endif
    endcase

    if gp_meta_description == blank
      assign gp_meta_description = 'Premium tempered glass mousepads with artwork sealed underneath. Smooth glide, easy clean, built to last.'
    endif
  -%}

  {% if gp_meta_description %}
    <meta name="description" content="{{ gp_meta_description | escape }}">
  {% endif %}
  <meta name="robots" content="{% if request.page_type == 'password' %}noindex, nofollow{% else %}index, follow{% endif %}">

  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%} Open Graph {%- endcomment -%}
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:description" content="{{ gp_meta_description | escape }}">
  {% if gp_meta_image != blank %}<meta property="og:image" content="{{ gp_meta_image }}">{% endif %}
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:type" content="{{ gp_meta_type }}">
  <meta property="og:site_name" content="{{ shop.name }}">

  {%- comment -%} Twitter Card {%- endcomment -%}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ page_title | escape }}">
  <meta name="twitter:description" content="{{ gp_meta_description | escape }}">
  {% if gp_meta_image != blank %}<meta name="twitter:image" content="{{ gp_meta_image }}">{% endif %}

  {%- if shop.published_locales.size > 1 -%}
    {%- for locale in shop.published_locales -%}
      <link rel="alternate" hreflang="{{ locale.iso_code }}" href="{{ shop.url }}{{ locale.root_url }}">
    {%- endfor -%}
    <link rel="alternate" hreflang="x-default" href="{{ shop.url }}">
  {%- endif -%}

  {%- comment -%} Resource hints — Shopify CDN + Google Fonts. {%- endcomment -%}
  <link rel="preconnect" href="https://cdn.shopify.com">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  {%- if request.page_type == 'product' and product.featured_image != blank -%}
    <link rel="preload" as="image" href="{{ product.featured_image | image_url: width: 1000 }}" fetchpriority="high">
  {%- endif -%}
  {%- comment -%}
    The homepage hero image doesn't need a matching preload here: its <img>
    (sections/gp-hero.liquid) already renders with loading="eager"
    fetchpriority="high", which gives the browser the same priority signal
    without guessing at a section setting that isn't visible from the layout.
  {%- endcomment -%}

  {%- comment -%}
    Critical CSS: hero + nav only, inlined so the first viewport paints
    without waiting on the full stylesheet. Keep this in sync by hand with
    gp-theme.css §1 (custom properties) and the Hero/Nav rules — it's a
    trimmed subset, not a generated build step, so don't let it grow past a
    few KB.
  {%- endcomment -%}
  <style>
    :root{--color-bg-primary:#0A0A0C;--color-bg-secondary:#141417;--color-text-primary:#F5F6F7;--color-text-secondary:#9B9DA3;--color-cyan:#5EE6D9;--color-border:#2A2B30;--color-text-on-cyan:#0A0A0C;--font-display:"Space Grotesk",sans-serif;--font-body:"Inter",sans-serif;--fs-h1:clamp(2.75rem,5vw,5rem);--container-width:{{ settings.container_width | default: 1280 }}px;--section-padding-y:clamp(3.5rem,{{ settings.section_padding | default: 7 }}vw,7rem);--radius-sm:8px;--ease-out:cubic-bezier(0.16,1,0.3,1)}
    *,*::before,*::after{box-sizing:border-box}
    body{margin:0;background:var(--color-bg-primary);color:var(--color-text-primary);font-family:var(--font-body);font-size:1rem;line-height:1.6;-webkit-font-smoothing:antialiased}
    img,svg,video{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    .gp-skip-link{position:absolute;left:-9999px;top:0;background:var(--color-cyan);color:var(--color-text-on-cyan);padding:.75rem 1.25rem;z-index:1000;border-radius:0 0 8px 0}
    .gp-skip-link:focus{left:0}
    .gp-container{width:100%;max-width:var(--container-width);margin:0 auto;padding:0 1.5rem}
    .gp-h1{font-family:var(--font-display);font-weight:600;font-size:var(--fs-h1);letter-spacing:-0.02em;line-height:1.05;margin:0}
    .gp-nav{background:var(--color-bg-primary);border-bottom:1px solid var(--color-border)}
    .gp-nav__inner{display:flex;align-items:center;justify-content:space-between;min-height:72px}
    .gp-nav__left{display:flex;align-items:center;gap:.75rem}
    .gp-nav__logo{font-family:var(--font-display);font-weight:600;letter-spacing:.02em}
    .gp-nav__links{display:none;align-items:center;gap:2rem}
    .gp-nav__actions{display:flex;align-items:center;gap:1.25rem}
    .gp-mobile-nav-toggle{background:none;border:0;color:var(--color-text-primary);padding:0}
    @media (min-width:768px){.gp-nav__links{display:flex}.gp-mobile-nav-toggle{display:none}}
    .gp-hero{position:relative;overflow:hidden;background:var(--color-bg-primary)}
    .gp-hero__media{position:relative;width:100%;padding-top:125%}
    .gp-hero__image,.gp-hero__video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
    .gp-hero__image--mobile{display:block}
    .gp-hero__image--desktop{display:none}
    .gp-hero__overlay{position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 30%,var(--color-bg-primary) 100%),rgba(10,10,12,var(--gp-hero-overlay,0.45))}
    .gp-hero__content{position:relative;z-index:2;padding-top:3rem;padding-bottom:3.5rem;text-align:center}
    .gp-hero__heading{color:var(--color-text-primary)}
    .gp-hero__subheading{max-width:640px;margin:1.25rem auto 0;color:var(--color-text-secondary);font-size:1.125rem}
    .gp-hero__actions{margin-top:2rem;display:flex;flex-direction:column;align-items:center;gap:.75rem}
    .gp-btn{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.9rem 1.75rem;border-radius:var(--radius-sm);font-family:var(--font-body);font-weight:600;font-size:1rem;white-space:nowrap}
    .gp-btn--primary{background:var(--color-cyan);color:var(--color-text-on-cyan);border:1px solid var(--color-cyan)}
    @media (max-width:767px){.gp-btn:not(.gp-btn--secondary){width:100%}}
    @media (min-width:768px){.gp-hero__media{padding-top:62%}.gp-hero__content{padding-top:4.5rem;padding-bottom:5rem}.gp-hero__actions{flex-direction:row;justify-content:center}}
    @media (min-width:1024px){.gp-hero__image--desktop{display:block}.gp-hero__image--mobile{display:none}}
  </style>

  {%- comment -%}
    Brand typography: Space Grotesk (display), Inter (body/UI), IBM Plex Mono
    (spec/labels). Loaded async (media="print" swapped to "all" on load) so
    it never blocks the first paint; font-display=swap in the Google Fonts
    URL itself avoids invisible text in the meantime. If the merchant picked
    font overrides in Typography settings, swap in their family names;
    otherwise keep the static brand URL.
  {%- endcomment -%}
  {%- liquid
    assign gp_custom_fonts = false
    if settings.heading_font != blank or settings.body_font != blank or settings.mono_font != blank
      assign gp_custom_fonts = true
    endif
  -%}
  {%- if gp_custom_fonts -%}
    {%- assign gp_heading_family = settings.heading_font.family | default: 'Space Grotesk' | replace: ' ', '+' -%}
    {%- assign gp_body_family = settings.body_font.family | default: 'Inter' | replace: ' ', '+' -%}
    {%- assign gp_mono_family = settings.mono_font.family | default: 'IBM Plex Mono' | replace: ' ', '+' -%}
    {%- capture gp_fonts_url -%}https://fonts.googleapis.com/css2?family={{ gp_heading_family }}:wght@500;600;700&family={{ gp_body_family }}:wght@400;500;600&family={{ gp_mono_family }}:wght@500&display=swap{%- endcapture -%}
  {%- else -%}
    {%- assign gp_fonts_url = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500&display=swap' -%}
  {%- endif -%}
  <link rel="stylesheet" href="{{ gp_fonts_url | strip }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ gp_fonts_url | strip }}"></noscript>

  {{ content_for_header }}

  {%- comment -%}
    Renders --font-display/--font-body/--font-mono from Typography settings
    before gp-theme.css loads, so a merchant's font override always wins the
    cascade tie once the async stylesheet applies.
  {%- endcomment -%}
  {% render 'gp-fonts' %}

  {%- comment -%} Full stylesheet loads async, same media-swap pattern, so it never blocks rendering. {%- endcomment -%}
  <link rel="stylesheet" href="{{ 'gp-theme.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ 'gp-theme.css' | asset_url }}"></noscript>

  {%- comment -%}
    gp-theme.css declares its own static :root defaults for --container-width
    / --section-padding-y. Because that stylesheet's <link> sits after the
    critical <style> above in document order, once it loads it would win the
    cascade tie and silently discard the Layout settings override — this
    block re-asserts them afterward so the theme editor setting always wins.
  {%- endcomment -%}
  <style>:root{--container-width:{{ settings.container_width | default: 1280 }}px;--section-padding-y:clamp(3.5rem,{{ settings.section_padding | default: 7 }}vw,7rem)}</style>

  {% render 'gp-jsonld' %}
</head>

<body class="template-{{ request.page_type }}">

  <a class="gp-skip-link" href="#MainContent">Skip to content</a>

  {%- comment -%}
    Announcement bar + primary nav share one sticky wrapper so dismissing
    the announcement collapses cleanly instead of leaving a gap under a
    separately-fixed nav. Both the desktop links and the mobile drawer
    render the same native "main-menu" linklist (Admin → Navigation) —
    owner adds/reorders/removes nav items with zero code. Recommended
    items: Home, Shop All, Artist Collection, Custom Artwork, Gallery,
    About, Contact.
  {%- endcomment -%}
  {%- assign gp_main_menu = linklists['main-menu'] -%}

  <div class="gp-site-header" data-gp-site-header>
    {% section 'gp-announcement-bar' %}

    <header class="gp-nav" data-gp-nav>
      <div class="gp-container gp-nav__inner">
        <div class="gp-nav__left">
          <button type="button" class="gp-mobile-nav-toggle" data-gp-mobile-nav-open aria-label="Open menu" aria-expanded="false" aria-controls="GpMobileNavDrawer">
            {% render 'gp-icon', icon: 'hamburger' %}
          </button>
          <a href="{{ routes.root_url }}" class="gp-nav__logo">GLASS PADS</a>
        </div>

        <nav class="gp-nav__links" aria-label="Primary">
          {%- for link in gp_main_menu.links -%}
            <a href="{{ link.url }}" class="gp-nav__link{% if link.active %} is-active{% endif %}">{{ link.title }}</a>
          {%- endfor -%}
        </nav>

        <div class="gp-nav__actions">
          <a href="{{ routes.search_url }}" class="gp-nav__action" aria-label="Search">
            {% render 'gp-icon', icon: 'search' %}
          </a>
          <button type="button" class="gp-nav__action gp-nav__cart-toggle" data-gp-cart-open aria-label="Open cart" aria-expanded="false" aria-controls="GpCartDrawer">
            {% render 'gp-icon', icon: 'shopping-bag' %}
            <span class="gp-nav__cart-badge" data-gp-cart-count>{{ cart.item_count }}</span>
          </button>
        </div>
      </div>
    </header>
  </div>

  <div class="gp-mobile-nav-overlay" data-gp-mobile-nav-overlay hidden></div>

  <div class="gp-mobile-nav-drawer is-closed" id="GpMobileNavDrawer" data-gp-mobile-nav-drawer inert>
    <div class="gp-mobile-nav-drawer__header">
      <a href="{{ routes.root_url }}" class="gp-nav__logo">GLASS PADS</a>
      <button type="button" class="gp-mobile-nav-drawer__close" data-gp-mobile-nav-close aria-label="Close menu">
        {% render 'gp-icon', icon: 'cross' %}
      </button>
    </div>

    <nav class="gp-mobile-nav-drawer__links" aria-label="Mobile">
      {%- for link in gp_main_menu.links -%}
        <a href="{{ link.url }}" class="gp-mobile-nav-link">{{ link.title }}</a>
      {%- endfor -%}
    </nav>

    <div class="gp-mobile-nav-drawer__footer">
      <div class="gp-mobile-nav-cta">
        {% render 'gp-button', text: 'Shop Glass Pads', url: '/collections/all', style: 'primary', full_width: true %}
      </div>

      <div class="gp-mobile-nav-drawer__socials">
        {%- if settings.social_instagram_link != blank -%}
          <a href="{{ settings.social_instagram_link }}" aria-label="Instagram">{% render 'gp-icon', icon: 'social-instagram' %}</a>
        {%- endif -%}
        {%- if settings.social_tiktok_link != blank -%}
          <a href="{{ settings.social_tiktok_link }}" aria-label="TikTok">{% render 'gp-icon', icon: 'social-tiktok' %}</a>
        {%- endif -%}
        {%- if settings.social_youtube_link != blank -%}
          <a href="{{ settings.social_youtube_link }}" aria-label="YouTube">{% render 'gp-icon', icon: 'social-youtube' %}</a>
        {%- endif -%}
        {%- if settings.social_x_link != blank -%}
          <a href="{{ settings.social_x_link }}" aria-label="X">{% render 'gp-icon', icon: 'social-x' %}</a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <main id="MainContent" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'gp-cart-drawer' %}
  {% section 'gp-newsletter-popup' %}
  {% section 'gp-quick-view' %}

  <script src="{{ 'gp-theme.js' | asset_url }}" defer="defer"></script>
</body>
</html>
